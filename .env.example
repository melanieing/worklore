# Supabase — project settings → API
NEXT_PUBLIC_SUPABASE_URL=
# 신규 publishable key (sb_publishable_...) 또는 레거시 anon key 중 하나
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# LLM 프로바이더 API 키 — 사용하는 라우팅의 프로바이더 키만 있으면 됨
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
# ANTHROPIC_API_KEY=

# AI 모델 라우팅 (형식: "provider:model-id", 기본값: src/lib/ai/models.ts)
# 라우팅/단가 결정은 docs/COSTS.md 참조
# AI_MODEL_LIGHT=openai:gpt-5-nano
# AI_MODEL_QUALITY=google:gemini-2.5-flash
# AI_MODEL_QUALITY_PRO=anthropic:claude-sonnet-4-6
